# Local Code Execution Engine - Environment Configuration
# Copy this file to .env and update values for your environment

# Required: API key for authentication
# Dev example: dev_key_12345678901234567890CHANGE_IN_PROD (min 32 chars, letters+numbers)
# Production: Generate random 64+ char key with crypto module (letters, numbers, symbols)
EXECUTOR_API_KEY=prod_change_me_to_strong_random_key_with_64_characters_minimum_here

# CORS Configuration (comma-separated origins, no spaces around commas)
# Dev: http://localhost:3000,http://localhost:8000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://portal.ojasamirai.com

# Optional: Logging configuration
LOG_LEVEL=INFO

# Optional: Execution configuration
EXECUTION_TIMEOUT=5
CONTAINER_MEMORY_MB=512
CONTAINER_CPU_LIMIT=0.5

# Optional: Server configuration
HOST=0.0.0.0
PORT=7999
